    {
      "id": "data_text",
      "type": "text",
      "x": 50, "y": 305,
      "width": 580, "height": 140,
      "text": "D1 (Toxic Fine-tune):  hate_speech18, ucberkeley-dlab/measuring-hate-speech\n  → 14K+ samples, toxic/hateful label filter\n\nD2 (Contrastive Triplets):  nbertagnolli/counsel-chat, Anthropic/hh-rlhf\n  → 14,089 train / 1,557 val triplets\n  → Negatives: LooksMaxGPT @ temp=0.3, max_new_tokens=128\n\nEval:  skg/toxigen-data (500 prompts), allenai/real-toxicity-prompts (500 prompts)",
      "fontSize": 12, "fontFamily": 3,
      "textAlign": "left", "verticalAlign": "top",
